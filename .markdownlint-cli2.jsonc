{
  "config": {
    "default": true,
    // Allow longer lines in markdown (methodology docs are verbose)
    "MD013": false,
    // Allow duplicate headings in different sections
    "MD024": { "siblings_only": true },
    // Allow inline HTML (badges, etc)
    "MD033": false,
    // Allow bare URLs
    "MD034": false
  },
  "ignores": [
    "node_modules/**",
    ".github/**"
  ]
}
